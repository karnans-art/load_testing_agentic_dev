# Copy to .env and fill in values
# Never commit .env to git

# CDS App
BASE_URL=https://uat-cds.tricogdev.net
TEST_EMAIL=your-test-user@domain.com
TEST_PASSWORD=your-password

# k6 Cloud (optional — needed only for production load testing)
K6_CLOUD_TOKEN=

# Datadog (optional — for baseline comparison and result push)
DD_API_KEY=
DD_APP_KEY=

# WAF time window
WAF_TIME_WINDOW_HOURS=24
