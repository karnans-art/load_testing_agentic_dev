{
  "name": "agentic-loadtesting",
  "version": "1.0.0",
  "description": "Production-replay load testing platform — simulates real traffic from WAF logs + HAR files",
  "type": "module",
  "scripts": {
    "smoke:cds":            "node runner/run-test.js --app cds --script smoke",
    "smoke:cds:cloud":      "node runner/run-test.js --app cds --script smoke --cloud",
    "peak:cds":             "node runner/run-test.js --app cds --script peak",
    "peak:cds:cloud":       "node runner/run-test.js --app cds --script peak --cloud",
    "stress:cds":           "node runner/run-test.js --app cds --script stress",
    "stress:cds:cloud":     "node runner/run-test.js --app cds --script stress --cloud",
    "production:cds":       "node runner/run-test.js --app cds --script production",
    "production:cds:cloud": "node runner/run-test.js --app cds --script production --cloud",
    "health:cds":           "node runner/run-test.js --app cds --script health-check",
    "websocket:cds":        "node runner/run-test.js --app cds --script websocket-test",
    "soak:cds":             "node runner/run-test.js --app cds --script soak-test",
    "soak:cds:cloud":       "node runner/run-test.js --app cds --script soak-test --cloud",
    "full-flow:cds":        "node runner/run-test.js --app cds --script full-doctor-flow",
    "full-flow:cds:cloud":  "node runner/run-test.js --app cds --script full-doctor-flow --cloud",
    "diagnosis:cds":        "node runner/run-test.js --app cds --script continuous-diagnosis",
    "diagnosis:cds:cloud":  "node runner/run-test.js --app cds --script continuous-diagnosis --cloud",
    "create-users:cds":     "node runner/create-users.js --app cds"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "imapflow": "^1.3.1"
  }
}
